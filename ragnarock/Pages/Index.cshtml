<!-- modul 4 -->
<section class="content-section" id="modul4">
    <div class="text-center">
        <h1>Test din viden!</h1>
            <div class="container">
                <h1>Hvor meget Gasolin' fan er du?</h1>

                @if (Model.CurrentQuestionIndex < Model.Questions.Count)
                {
                    var question = Model.Questions[Model.CurrentQuestionIndex];

                    <div class="quiz-card">
                        <h4>@question.Question</h4>

                        <div class="quiz-options">
                        <!-- action="#modul4" laver anchor så man bliver ved quizzen efter hvert submit -->
                        <form method="post" action="#modul4">
                            <input type="hidden" name="questionIndex" value="@Model.CurrentQuestionIndex" />
                            <input type="hidden" name="score" value="@Model.Score" />

                            @foreach (var answer in question.Options)
                            {
                                <button type="submit" name="selectedAnswer" value="@answer" class="quiz-btn">
                                    @answer
                                </button>
                 
                            }
                        </form>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Result))
                    {
                        <p class="quiz-result">@Model.Result</p>
                    }
                }
                else
                {
                    <div class="quiz-card">
                        <h4>Quiz færdig 🎉</h4>
                        <p>Din score er: @Model.Score / @Model.Questions.Count</p>
                    </div>

                    <!-- Prøv igen knap-->
                    <form method="get"> 
                        <button type="submit" class="retry-btn">Prøv igen</button>
                    </form>

                }
            </div>
    </div>
</section>


